# ─────────────────────────────────────────────
# Backend — NestJS
# Copia este archivo como .env antes de iniciar
# ─────────────────────────────────────────────

NODE_ENV=development

# ── Servidor ──────────────────────────────────
PORT=3000

# ── API Key (obligatoria) ─────────────────────
# Mismo valor que API_KEY en Vercel. Generar con: openssl rand -hex 32
API_KEY=genera_un_valor_largo_aleatorio_aqui

# ── Base de datos (PostgreSQL / Neon) ──────────
# Opción A (recomendada en Render): pegar el connection string de Neon
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Opción B: variables separadas
DB_HOST=ep-xxxx-pooler.region.aws.neon.tech
DB_PORT=5432
DB_USERNAME=neondb_owner
DB_PASSWORD=your_neon_password
DB_NAME=neondb
DB_SSL=true

# ── CORS ──────────────────────────────────────
# Varias URLs separadas por coma, sin / al final
CORS_ORIGIN=http://localhost:4200,https://portfolio-monorepo-two.vercel.app
# Permite cualquier preview *.vercel.app (recomendado con Vercel)
CORS_ALLOW_VERCEL=true
